# SharePoint Graph API Configuration
# Preencha com seus valores e renomeie para .env ou configure em /etc/sek-plano-ops/config.env

# Tenant ID do tenant do proofcrm (ex: "00001111-2222-3333-4444-555555666666")
PLANO_OPS_SP_TENANT=""

# Client ID do App Registration (ex: "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee")
PLANO_OPS_SP_CLI_ID=""

# Client Secret do App Registration
PLANO_OPS_SP_CLI_SEC=""

# TTL do cache em segundos (padrão: 7 dias = 604800)
PLANO_OPS_CACHE_TTL=604800

# URL do SharePoint (deixar padrão)
PLANO_OPS_SP_HOST=proofcrm.sharepoint.com

# Site SharePoint (deixar padrão)
PLANO_OPS_SP_SITE=SOCPROOF

# Pasta dentro do site (deixar padrão)
PLANO_OPS_SP_FOLDER="Documentos Compartilhados/Clientes, Governança e Controles/Plano de Operação"

# Diretório local para fallback (se SharePoint falhar)
PLANO_OPS_LOCAL_DIR=/opt/sek-paloalto-agent/planos_operacao
